def load_dataset(base_path, event_type, subclass, bar, case, target_size=(64,64), next_bar=None):
    """Same file names as your loader but resize to target_size and normalize."""
    phases = ['FaseA', 'FaseB', 'FaseC']
    img_arrays = []

    event_folder = {"low_impedance": "FBI", "high_impedance": "FAI", "capacitor_switching": "CBC"}
    event_path = os.path.join(base_path, event_folder[event_type])
    event_path = os.path.join(event_path, str(subclass_labels[subclass]))

    barra_str = f'Barra{bar}' if next_bar is None else f'Barra{bar}_{next_bar}'

    for phase in phases:
        base_img_name = f'{barra_str}_Caso{case}_{phase}.{forma}'
        base_img_path = os.path.join(event_path, base_img_name)
        try:
          img_array = fast_load(base_img_path, target_size)
          if img_array is None:
           return None
          img_arrays.append(img_array)
        except Exception:
            return None

        for h in range(1,8):
            harmonic_img_name = f'{barra_str}_Caso{case}_{phase}_{h}.{forma}'
            harmonic_img_path = os.path.join(event_path, harmonic_img_name)
            try:
             img_array = fast_load(harmonic_img_path, target_size)
             if img_array is None:
              return None
             img_arrays.append(img_array)
            except Exception:
                return None

    if len(img_arrays) == 24:
        return np.concatenate(img_arrays, axis=-1)  # shape = (H, W, 24)
    else:
        return None
    
def filter_odd_harmonics_from_cache(X_all):
    """
    Filter 24-channel cache to keep only pair harmonics:
    - Harmonic 1 (fundamental)
    - Harmonic 2 (even)
    - Harmonic 4 (even) 
    - Harmonic 6 (even)
    
    From 24 channels (3 phases × 8 components) to 12 channels (3 phases × 4 harmonics)
    """
    print(f"Original X shape: {X_all.shape}")
    
    if X_all.shape[-1] == 24:
        print("Filtering 24 channels → 15 channels (harmonics 1, 3, 5, 7)")
        
        # Channel mapping for 24 channels (3 phases × 8 components):
        # Phase A: channels 0-7  [full_signal, h1, h2, h3, h4, h5, h6, h7]
        # Phase B: channels 8-15 [full_signal, h1, h2, h3, h4, h5, h6, h7]  
        # Phase C: channels 16-23 [full_signal, h1, h2, h3, h4, h5, h6, h7]
        
        # We want to keep for each phase: h1(1), h2(2), h4(4), h6(6)
        channels_to_keep = []
        for phase in range(3):  # 3 phases
            phase_start = phase * 8
            # Keep: whole signal, whole signal, h1(1), h3(3), h5(5) and h7(7)
            channels_to_keep.extend([phase_start, phase_start + 1, phase_start + 3, phase_start + 5, phase_start+7])
        
        X_filtered = X_all[:, :, :, channels_to_keep]
        print(f"Filtered X shape: {X_filtered.shape}")
        print("✅ Kept channels: whole signal and harmonics 1, 3, 5, 7 for each phase")
        return X_filtered
    
    elif X_all.shape[-1] == 15:
        print("✅ Cache already has 15 channels (pair harmonics only)")
        return X_all
    else:
        print(f"⚠️ Unexpected number of channels: {X_all.shape[-1]}")
        return X_all

