def build_and_save_cache(cache_filename=CACHE_FILENAME, img_size=CACHE_IMG_SIZE):
    print("🚀 Building cache:", cache_filename)
    X_list = []
    y_list = []

    between_bars = [(1, 2), (5, 6), (10, 11)]

    # reuse your same mappings: main_labels, subclass_labels, flat_labels, base_path
    for event_type in main_labels.keys():
        if event_type == "low_impedance":
            for subclass in ["PG", "PP", "PPG", "PPP"]:
                flat_class = flat_labels[f"low_impedance_{subclass}"]
                # Normal barras
                for bar in range(1, 12):
                    for case in range(1, 31):
                        sample = load_dataset(base_path, event_type, subclass, bar, case, img_size)
                        if sample is not None:
                            append_X = X_list.append
                            append_Y = y_list.append
                            append_X(sample)
                            append_Y(flat_class)
                # Entre-barras
                for (bar1, bar2) in between_bars:
                    for case in range(1, 31):
                        sample = load_dataset(base_path, event_type, subclass, bar1, case, img_size, next_bar=bar2)
                        if sample is not None:
                            append_X = X_list.append
                            append_Y = y_list.append
                            append_X(sample)
                            append_Y(flat_class)

        elif event_type == "high_impedance":
            for subclass in ["PG"]:
                flat_class = flat_labels["high_impedance_PG"]
                for bar in range(1, 12):
                    for case in range(1, 31):
                        sample = load_dataset(base_path, event_type, subclass, bar, case, img_size)
                        if sample is not None:
                            append_X = X_list.append
                            append_Y = y_list.append
                            append_X(sample)
                            append_Y(flat_class)
                for (bar1, bar2) in between_bars:
                    for case in range(1, 31):
                        sample = load_dataset(base_path, event_type, subclass, bar1, case, img_size, next_bar=bar2)
                        if sample is not None:
                            append_X = X_list.append
                            append_Y = y_list.append
                            append_X(sample)
                            append_Y(flat_class)

        elif event_type == "capacitor_switching":
            for subclass in ["PPP"]:
                flat_class = flat_labels["capacitor_switching_PPP"]
                for bar in [1, 6, 11]:
                    for case in range(1, 91):
                        sample = load_dataset(base_path, event_type, subclass, bar, case, img_size)
                        if sample is not None:
                            append_X = X_list.append
                            append_Y = y_list.append
                            append_X(sample)
                            append_Y(flat_class)

    # stack and save with metadata signature
    X = np.stack(X_list).astype(np.float32)
    y = np.array(y_list, dtype=np.int32)

    meta = {"signature": compute_signature(), "created_at": datetime.datetime.now().isoformat()}
    np.savez(cache_filename, X=X, y=y, meta=json.dumps(meta))
    print(f"✅ Cache built: {cache_filename}  |  X.shape={X.shape}, y.shape={y.shape}")
    return X, y

