# Simplified model for 6 flat classes
def build_flat_model(input_shape=(64, 64, 15)):
    input_layer = Input(shape=input_shape)

    x = Conv2D(32, (3, 3), activation='relu', kernel_initializer='he_normal')(input_layer)
    x = MaxPooling2D((2, 2))(x)
    x = Dropout(0.2)(x)
    
    x = Conv2D(64, (3, 3), activation='relu', kernel_initializer='he_normal')(x)
    x = MaxPooling2D((2, 2))(x)
    x = Dropout(0.2)(x)
     
    x = Flatten()(x)
    x = Dense(128, activation='relu', kernel_initializer='he_normal')(x)
    x = BatchNormalization()(x)  # Add BatchNorm

    # SINGLE OUTPUT for 6 flat classes
    output = Dense(6, activation='softmax', name='output', kernel_initializer='glorot_uniform')(x)

    model = Model(inputs=input_layer, outputs=output)

    model.compile(
        optimizer=tf.keras.optimizers.Adam(learning_rate=0.00025, clipnorm = 1.5),
        loss='sparse_categorical_crossentropy',
        metrics=['accuracy']
    )
    return model

