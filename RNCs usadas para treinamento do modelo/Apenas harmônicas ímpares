# ------------------ CACHE VALIDATION HELPERS ------------------
def compute_signature():
    """Compute a small signature representing the dataset-related config.
    Change any of these variables when your data format changes so the cache invalidates.
    """
    important_parts = f"CACHE_IMG_SIZE={CACHE_IMG_SIZE};HARMONICS={HARMONICS}"
    return hashlib.md5(important_parts.encode()).hexdigest()


def validate_cache(cache_file, expected_img_size, expected_channels, signature):
    """Return True if cache looks valid; otherwise False.
    Checks:
      - file exists and can be loaded
      - contains X, y and meta
      - X has the expected spatial size and channel count
      - saved signature matches current signature
    """
    if not os.path.exists(cache_file):
        print("ℹ️ Nenhum cache encontrado.")
        return False

    # ---- SAFE LOAD (prevents Windows locking the file) ----
    try:
        with np.load(cache_file) as data:
            # ensure required keys exist
            if "X" not in data or "y" not in data or "meta" not in data:
                print("⚠️ Cache incompleto (faltam X/y/meta) — reconstruindo.")
                return False

            X = data["X"]
            meta_raw = data["meta"]
    except Exception as e:
        print("⚠️ Cache corrompido ou ilegível — reconstruindo. Error:", e)
        return False

    # ---- decode meta ----
    try:
        meta = json.loads(str(meta_raw))
    except Exception as e:
        print("⚠️ Falha ao ler conteúdo do cache — reconstruindo. Error:", e)
        return False

    # ---- spatial size check ----
    if tuple(X.shape[1:3]) != tuple(expected_img_size):
        print(f"⚠️ Tamanho inconsistente ({X.shape[1:3]} != {expected_img_size}) — reconstruindo.")
        return False

    # ---- channel count ----
    if X.shape[-1] != expected_channels:
        print(f"⚠️ Canais incorretos ({X.shape[-1]} != {expected_channels}) — reconstruindo.")
        return False

    # ---- signature check ----
    if meta.get("signature") != signature:
        print("⚠️ Assinatura do código/dados mudou — reconstruindo o cache.")
        return False

    print("✅ Cache validado com sucesso.")
    return True

# ------------------ FAST LOADER ------------------

def fast_load(path, target_size):
    try:
        img_bytes = tf.io.read_file(path)
        img = tf.image.decode_png(img_bytes, channels=1)
        img = tf.image.resize(img, target_size, method='bilinear')
        return img.numpy().astype(np.float32) / 255.0
    except Exception:
        return None

