    for label in cbar.ax.get_yticklabels():
        label.set_fontweight('bold')
    
    # Set labels with BOLD font
    ax.set_xticks(np.arange(len(class_names)))
    ax.set_yticks(np.arange(len(class_names)))
    ax.set_xticklabels(class_names, fontsize=18, fontweight='bold')
    ax.set_yticklabels(class_names, fontsize=18, fontweight='bold')
    
    # Rotate x labels
    plt.setp(ax.get_xticklabels(), rotation=45, ha="right", rotation_mode="anchor")
    
    # Add text annotations with MUCH LARGER font
    for i in range(len(class_names)):
        for j in range(len(class_names)):
            text_color = 'white' if cm_percent[i, j] > 50 else 'black'
            ax.text(j, i, annotations[i][j],
                   ha="center", va="center", 
                   color=text_color, fontweight='bold', fontsize=22)
    
    # Title with BOLD font
    if DATASET_TYPE in ["60dB" , "40dB" , "20dB"]:
        ax.set_title(f'Matriz de Confusão\nRuído de {DATASET_TYPE}\nAcurácia: {accuracy:.2f}%', 
                    fontsize=26, fontweight='bold', pad=30)
    elif DATASET_TYPE in ["5%" , "10%" , "30%"]:
        ax.set_title(f'Matriz de Confusão\n{DATASET_TYPE} de Dados Perdidos\nAcurácia: {accuracy:.2f}%', 
                    fontsize=26, fontweight='bold', pad=30)    
    else:
        ax.set_title(f'Matriz de Confusão\nSem Ruído\nAcurácia: {accuracy:.2f}%', 
                    fontsize=26, fontweight='bold', pad=30)
    
    # Axis labels with BOLD font
    ax.set_xlabel('Classe Prevista', fontsize=24, fontweight='bold', labelpad=20)
    ax.set_ylabel('Classe Real', fontsize=24, fontweight='bold', labelpad=20)
    
    # Add grid
    ax.set_xticks(np.arange(-0.5, len(class_names), 1), minor=True)
    ax.set_yticks(np.arange(-0.5, len(class_names), 1), minor=True)
    ax.grid(which="minor", color="gray", linestyle='-', linewidth=0.5)
    ax.tick_params(which="minor", size=0)
    
    plt.tight_layout()
    
    # Save as PNG
    cm_filename = f'flat_confusion_matrix_{timestamp}.png'
    cm_path = os.path.join(results_dir, cm_filename)
    plt.savefig(cm_path, dpi=300, bbox_inches='tight', facecolor='white')
    plt.show()
    
    print(f"✅ Confusion matrix saved to: {cm_filename}")
    
    return cm, cm_percent

def verify_data_splits(x_train, y_train, x_test, y_test):
    """Verify that train/test splits are actually different"""
    print("\n" + "="*60)
    print("DATA SPLIT VERIFICATION")
    print("="*60)
    
    # Check for exact duplicates between train and test
    train_hashes = [hash(x_train[i].tobytes()) for i in range(len(x_train))]
    test_hashes = [hash(x_test[i].tobytes()) for i in range(len(x_test))]
    
    duplicates = set(train_hashes) & set(test_hashes)
    print(f"Exact duplicates between train/test: {len(duplicates)}")
    
    if len(duplicates) > 0:
        print("🚨 DATA LEAKAGE DETECTED: Same samples in both sets!")
    
    # Check class distribution
    print(f"\nTraining class distribution:")
    train_counts = np.bincount(y_train)
    for i, count in enumerate(train_counts):
        print(f"  {class_names[i]}: {count} samples")
    
    print(f"\nTest class distribution:")
    test_counts = np.bincount(y_test)
    for i, count in enumerate(test_counts):
        print(f"  {class_names[i]}: {count} samples")

def train_flat_model(x_data, y_classes, test_size=0.2):
    print(f"\nTraining FLAT model - test size: {test_size}")

    if len(x_data) == 0:
        print("No data available for training.")
        return None

    # --- Stratified split for flat classes ---
    strat_split = StratifiedShuffleSplit(n_splits=1, test_size=test_size, random_state=42)
    for train_idx, test_idx in strat_split.split(x_data, y_classes):
        x_train, x_test = x_data[train_idx], x_data[test_idx]
        y_train, y_test = y_classes[train_idx], y_classes[test_idx]
    
    # VERIFY THE SPLIT
    verify_data_splits(x_train, y_train, x_test, y_test)
    
    print(f"Amostras de treino: {len(x_train)}, Amostras de teste: {len(x_test)}")

    # --- Build model ---
    model = build_flat_model(input_shape=x_data.shape[1:])
    
    print("Starting training...")
    start_time = datetime.datetime.now()
    
    history = model.fit(
        x_train,
        y_train,
        validation_data=(x_test, y_test),
        epochs=30,
        batch_size=32,
        verbose=1,
        callbacks=[early_stop,reduce_lr]
    )
    
    training_time = datetime.datetime.now() - start_time
    print(f"Treinamento completo em: {training_time}")

    # --- Predictions ---
    y_pred_probs = model.predict(x_test)
    y_pred_classes = np.argmax(y_pred_probs, axis=1)
    
    # Generate timestamp for this run
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        
    # === SAVE PER-EPOCH ACCURACIES TO CSV ===
    epoch_data = {
        'epoch': list(range(1, len(history.history['loss']) + 1)),
        'train_accuracy': history.history['accuracy'],
        'val_accuracy': history.history['val_accuracy'],
        'train_loss': history.history['loss'],
        'val_loss': history.history['val_loss']
    }
    
    # Create detailed epoch-by-epoch DataFrame
    epoch_df = pd.DataFrame(epoch_data)
    
    # Save detailed epoch data to CSV
    epoch_filename = f'flat_epoch_history_{timestamp}.csv'
    epoch_path = os.path.join(results_dir, epoch_filename)
    epoch_df.to_csv(epoch_path, index=False)
    
    print(f"✅ Per-epoch accuracy history saved to: {epoch_filename}")
    
    # Plot training curves
    best_epoch_acc, best_acc, best_epoch_loss, best_loss = plot_flat_training_curves_separate(epoch_df, timestamp)
    
    # Calculate comprehensive metrics
    metrics_dict = calculate_flat_metrics(y_test, y_pred_classes, "FLAT CLASSES", timestamp)
    
    # Save combined metrics to JSON file in results folder
    combined_metrics_data = {
        'timestamp': timestamp,
        'test_size': test_size,
        'training_time_seconds': training_time.total_seconds(),
        'training_time_human_readable': str(training_time),
        'final_epoch': len(history.history['loss']),
        'final_train_accuracy': history.history['accuracy'][-1],
        'final_val_accuracy': history.history['val_accuracy'][-1],
        'best_val_accuracy': max(history.history['val_accuracy']),
        'metrics': metrics_dict,
        'training_samples': len(x_train),
        'test_samples': len(x_test),
        'best_epoch_accuracy': int(best_epoch_acc),
        'best_val_accuracy': float(best_acc),
        'best_epoch_loss': int(best_epoch_loss), 
        'best_val_loss': float(best_loss),
        'class_distribution': {
            'training': {int(k): int(v) for k, v in zip(*np.unique(y_train, return_counts=True))},
            'testing': {int(k): int(v) for k, v in zip(*np.unique(y_test, return_counts=True))}
        }
    }
    
    combined_metrics_filename = f'flat_comprehensive_metrics_{timestamp}.json'
    combined_metrics_path = os.path.join(results_dir, combined_metrics_filename)
    with open(combined_metrics_path, 'w') as f:
        json.dump(combined_metrics_data, f, indent=2)
    
    # Create and save summary CSV to results folder
    summary_data = {
        'timestamp': [timestamp],
        'test_size': [test_size],
        'training_time_seconds': [training_time.total_seconds()],
        'final_epoch': [len(history.history['loss'])],
        'final_train_accuracy': [history.history['accuracy'][-1]],
        'final_val_accuracy': [history.history['val_accuracy'][-1]],
        'best_val_accuracy': [max(history.history['val_accuracy'])],
        'accuracy': [metrics_dict['accuracy']],
        'f1_macro': [metrics_dict['f1_macro']],
        'training_samples': [len(x_train)],
        'test_samples': [len(x_test)]
    }
    
    df_summary = pd.DataFrame(summary_data)
    summary_filename = f'flat_model_summary_{timestamp}.csv'
    summary_path = os.path.join(results_dir, summary_filename)
    df_summary.to_csv(summary_path, index=False)
    
    # Save training history to CSV in results folder (original format)
    history_df = pd.DataFrame(history.history)
    history_df.insert(0, 'epoch', range(1, len(history_df) + 1))
    history_filename = f'flat_training_history_{timestamp}.csv'
    history_path = os.path.join(results_dir, history_filename)
    history_df.to_csv(history_path, index=False)
    
    # Plot and save class distribution
    plot_flat_class_distribution(y_classes, timestamp)
    
    # Plot confusion matrix
    plot_flat_conf_matrix(y_test, y_pred_classes, timestamp)
    
    print(f"\n✅ All results saved to '{results_dir}' folder:")
    print(f"   📊 {combined_metrics_filename} (combined metrics)")
    print(f"   📈 {summary_filename} (summary CSV)")
    print(f"   📋 {history_filename} (training history)")
    print(f"   📊 {epoch_filename} (per-epoch accuracy history)")

    # --- Classification Report ---
    print("\n===== FLAT CLASSES REPORT =====")
    print(classification_report(
        y_test, y_pred_classes,
        target_names=class_names,
        digits=4
    ))

    return model, history, (x_test, y_test, y_pred_classes), combined_metrics_data

