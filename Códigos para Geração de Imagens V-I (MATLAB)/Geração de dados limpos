    phasors_IB(1,m) = complex((sqrt(2)/N_ciclo)*Xkc_IB,-(sqrt(2)/N_ciclo)*Xks_IB); %%estimação do fasor inicial
    
    Xkc_IC = Xkc_IC + I_faseC(n)*cos(m*(n-1)*theta); %Componente real do fasor
