    %% FUNÇÃO DE RUÍDO GAUSSIANO CORRELACIONADO
function [sinal_ruidoso1, sinal_ruidoso2] = adicionar_ruido_gaussiano_correlacionado(sinal_clean1, sinal_clean2, SNR_dB)
% ADICIONAR_RUIDO_GAUSSIANO_CORRELACIONADO - Aplica ruído gaussiano correlacionado a dois sinais
% O mesmo instante de ruído é aplicado a ambos os sinais (simula mesmo sensor/transformador)
%
% Inputs:
%   sinal_clean1 - Primeiro sinal limpo (ex: corrente)
%   sinal_clean2 - Segundo sinal limpo (ex: tensão)  
%   SNR_dB - Signal-to-Noise Ratio em dB
%
% Outputs:
%   sinal_ruidoso1 - Primeiro sinal com ruído
%   sinal_ruidoso2 - Segundo sinal com ruído

    % Validar entrada
    if nargin < 3
        SNR_dB = 30; % Valor padrão
    end
    
    % Calcular potência do sinal de referência (usar o primeiro sinal como referência)
    potencia_sinal = mean(sinal_clean1.^2);
    
    % Calcular potência do ruído baseado no SNR
    potencia_ruido = potencia_sinal / (10^(SNR_dB/10));
    
    % Gerar UMA única sequência de ruído para ambos os sinais
    ruido_comum = sqrt(potencia_ruido) * randn(size(sinal_clean1));
    
    % Aplicar o MESMO ruído a ambos os sinais (correlacionado no tempo)
    sinal_ruidoso1 = sinal_clean1 + ruido_comum;
    sinal_ruidoso2 = sinal_clean2 + ruido_comum;
    
end

    
        
